/dts-v1/;

#include <nxp/nxp_rt11xx_cm7.dtsi>
#include "maax_imxrt1176.dtsi"

/ {
	model = "Avnet MaaXBoard RT1176 board";
	compatible = "nxp,mimxrt1176";

	aliases {
		watchdog0 = &wdog1;
	};

chosen {
    zephyr,flash-controller = &S26KS256;
    zephyr,flash = &S26KS256;
    zephyr,code-partition = &slot0_partition;
    //zephyr,sram = &sdram0;
		zephyr,sram = &dtcm;
    zephyr,dtcm = &dtcm;
    zephyr,itcm = &itcm;
    zephyr,console = &lpuart1;
    zephyr,shell-uart = &lpuart1;
    zephyr,canbus = &flexcan3;
    zephyr,cpu1-region = &ocram;
    zephyr,ipc = &mailbox_a;
};

	sdram0: memory@80000000 {

		device_type = "memory";
		reg = <0x80000000 DT_SIZE_M(32)>;
	};
};

&lpuart1 {
	status = "okay";
	current-speed = <115200>;
};

&flexcan3 {
	status = "okay";
	can-transceiver {
		max-bitrate = <5000000>;
	};
};

&lpspi1 {
	dmas = <&edma0 0 36>, <&edma0 1 37>;
	dma-names = "rx", "tx";
	status = "okay";
};

&lpadc0 {
	status = "okay";
};

&usdhc1 {
	status = "okay";
	detect-dat3;
	pwr-gpios = <&gpio10 2 GPIO_ACTIVE_LOW>;
	sdmmc {
		compatible = "zephyr,sdmmc-disk";
		status = "okay";
	};
};

&edma0 {
	status = "okay";
};

/* GPT and Systick are both enabled. If power management is enabled, GPT
 * will be used instead of systick as it allows the core clock to be gated.
 */
&gpt_hw_timer {
	status = "okay";
};

&systick {
	status = "okay";
};

&wdog1 {
	status = "okay";
};

&sai1 {
	status = "okay";
};

zephyr_udc0: &usb1 {
	status = "okay";
	phy_handle = <&usbphy1>;
};

&usbphy1 {
	status = "okay";
	tx-d-cal = <7>;
	tx-cal-45-dp-ohms = <6>;
	tx-cal-45-dm-ohms = <6>;
};

&mailbox_a {
	status = "okay";
};

&pit1 {
	status = "okay";
};

&pit2 {
	status = "okay";
};
