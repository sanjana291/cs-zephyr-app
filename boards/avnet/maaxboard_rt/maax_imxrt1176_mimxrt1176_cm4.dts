/dts-v1/;

#include <nxp/nxp_rt11xx_cm4.dtsi>
#include "maax_imxrt1176.dtsi"

/ {
	model = "Avnet MaaXBoard RT1176 board";
	compatible = "nxp,mimxrt1176";

	chosen {
    zephyr,flash-controller = &S26KS256;
    zephyr,flash = &sram0;
    zephyr,sram = &sram1;
    zephyr,console = &lpuart1;
    zephyr,shell-uart = &lpuart1;
    zephyr,canbus = &flexcan2;
    nxp,m4-partition = &slot1_partition;
    zephyr,ipc = &mailbox_b;
	};

	sdram0: memory@80000000 {
		/* Winbond W9825G6KH-5I */
		device_type = "memory";
		reg = <0x80000000 DT_SIZE_M(64)>;
	};
};

&lpuart1 {
	status = "okay";
	current-speed = <115200>;
};

&lpi2c1 {
	status = "okay";
};

/* GPT and Systick are both enabled. If power management is enabled, GPT
 * will be used instead of systick as it allows the core clock to be gated.
 */
&gpt_hw_timer {
	status = "okay";
};

&systick {
	status = "okay";
};

&sai1 {
	status = "okay";
};

&edma_lpsr0 {
	status = "okay";
};

&mailbox_b {
	status = "okay";
};
